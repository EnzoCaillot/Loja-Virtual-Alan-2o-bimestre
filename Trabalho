<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        body{
            background:rgb(224, 224, 224);
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
        }
        .Cabecalho{
            background-color:black;
            gap: 10px;
            justify-content: space-around;
            display: flex;
            align-items: center;
        }
        .ícone{
            width: 75px;
            height: 75px;
        }
        .BarraPesquisa{
            border-radius: 10px;
            width: 400px;
            height: 50px;
            background-color: white;
            margin: 10px;
            border: none;
        }
        .links{
            display: flex;
            flex-direction: column;
            color: white;
            margin: 10px;
        }
        .AlaProdutos{
            display: flex;
            gap: 15px;
            margin: 15px;
            align-items: center;
            justify-content: center;
        }
        .Produtos{
            background-color: white;
            border-radius: 18px;
            width: 320px;
            margin: 10px;
            height: 500px;
            display: flex;
            flex-direction: column;
        }
        .imgProdutos{
            width: 180px;
            height: 260px;
            border-radius: 10px;
            margin: 20px;
            margin-bottom: 20px;
            object-fit: cover;
            align-self: center;
        }
        .nomePorduto{
            font-size: 23px;
            margin: 5px;
            font-weight: bold;
        }
        .Dinheiro{
            font-size: 28px;
            color: red;
            font-weight: bold;
            margin: 15px;
        }
        .Botao{
            background-color: black;
            color: white;
            border: none;
            border-radius: 10px;
            width: 290px;
            margin: 15px;
            height: 50px;
            cursor: pointer;
        }
        .AlaFormulário{
            background-color: black;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .Formulário{
            background-color: white;
            display: flex;
            flex-direction: column;
            margin: 20px;
            padding: 10px;
            border-radius: 10px;
            gap: 5px;
        }

        .BotaoEnviar{
            background-color: black;
            color: white;
            border-radius: 5px;
            cursor: pointer;
        }
        .CreditosFinais{
            background-color: black;
            color: white;
            font-family: 'Times New Roman', Times, serif;
            text-align: center;
            margin: 0;
        }
    </style>

</head>
<body>
    <div class="Cabecalho">
        <img src="https://static.vecteezy.com/system/resources/previews/020/336/432/non_2x/steam-logo-steam-icon-free-free-vector.jpg" alt="ícone Steam" class="ícone">
        <input type="text" class="BarraPesquisa" placeholder="Pesquise Aqui...">
            <div class="links">
                <a href="#Produtos" class="links">Produtos</a>
                <a href="oi" class="links">Formulário</a>
            </div>
    </div>
    
    <img src="https://steamcdn-a.akamaihd.net/steamcommunity/public/images/steamworks_docs/brazilian/Header_1.jpg" alt="banner steam">

    <div class="AlaProdutos" id="#Produtos">
        <div class="Produtos">
            <img class="imgProdutos"src="https://static.wikia.nocookie.net/hollowknight/images/c/cd/HK_Cover_Art.png/revision/latest/thumbnail/width/360/height/360?cb=20220613045755&path-prefix=pt">
            <p class="nomePorduto">Hollow Knight</p>
            <p class="Dinheiro">R$23,00</p>
            <button class="Botao">Comprar</button>
        </div>
        <div class="Produtos">
            <img class="imgProdutos"src="https://cdn2.steamgriddb.com/thumb/d85c154ebb9bdcc43e5174912f08cade.jpg">
            <p class="nomePorduto">Hollowknight: Silksong</p>
            <p class="Dinheiro">R$59,99</p>
            <button class="Botao">Comprar</button>
        </div>
        <div class="Produtos">
            <img class="imgProdutos"src="https://m.media-amazon.com/images/I/51fl1xl8t8L._AC_UF1000,1000_QL80_.jpg">
            <p class="nomePorduto">Final Fantasy Collection I-VI</p>
            <p class="Dinheiro">R$375,00</p>
            <button class="Botao">Comprar</button>
        </div>
        <div class="Produtos">
            <img class="imgProdutos"src="https://cdn2.steamgriddb.com/grid/8a27d37cd175197e87c02a7fc7eb192d.png">
            <p class="nomePorduto">Red Dead Redemption 2</p>
            <p class="Dinheiro">R$299,00</p>
            <button class="Botao">Comprar</button>
        </div>
    </div>

    <div class="AlaProdutos">
        <div class="Produtos">
            <img class="imgProdutos"src="https://m.media-amazon.com/images/I/71y3B3VLlLL._AC_UF1000,1000_QL80_.jpg">
            <p class="nomePorduto">Tomodachi Life: Living a Dream</p>
            <p class="Dinheiro">R$329,90</p>
            <button class="Botao">Comprar</button>
        </div>
        <div class="Produtos">
            <img class="imgProdutos"src="https://m.media-amazon.com/images/I/61ax3Tz3SxL._AC_UF1000,1000_QL80_.jpg">
            <p class="nomePorduto">The Legend of Zelda: Breath of the Wild</p>
            <p class="Dinheiro">R$349,00</p>
            <button class="Botao">Comprar</button>
        </div>
        <div class="Produtos">
            <img class="imgProdutos"src="https://m.media-amazon.com/images/I/6110RSDn3PL.jpg" height="350px">
            <p class="nomePorduto">Elden Ring: The Complete Saga</p>
            <p class="Dinheiro">R$570,00</p>
            <button class="Botao">Comprar</button>
        </div>
        <div class="Produtos">
            <img class="imgProdutos"src="https://cdn2.steamgriddb.com/thumb/a29b4277db29fac190b2a8d6c13dbc95.jpg" height="3  50px">
            <p class="nomePorduto">Cuphead: Dont deal with the Devil</p>
            <p class="Dinheiro">R$36,99</p>
            <button class="Botao">Comprar</button>
        </div>
    </div>

    <div class="AlaFormulário">
        <div class="Formulário">
            <input type="text" placeholder="Seu nome...">
            <input type="email" placeholder="Seu E-mail..">
            <input type="submit" placeholder="Enviar" class="BotaoEnviar">
        </div>
    </div>

    <p class="CreditosFinais">Feito com muito ódio por Enzo Caillot Marques</p>

</body>
</html>
